# Google Cloud Configuration
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/your-service-account-key.json
# Same key file inside Docker (/app is the repo root). Basename must match GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS_CONTAINER=/app/credentials/your-service-account-key.json
GOOGLE_REGION=us-central1

# GCS raw data (Kaggle favorita CSVs uploaded to GCS)
GCS_RAW_DATA_BUCKET=gs://your-bucket-name/raw/favorita

# Kaggle API (https://www.kaggle.com/settings/api → Generate New Token)
# Passed into Docker via docker-compose; alternative: ~/.kaggle/kaggle.json or access_token
KAGGLE_API_TOKEN=KGAT_xxxxxxxxxxxxxxxxxxxxxxxxx
# Kaggle credentials directory (mounted into Docker at /root/.kaggle; default: ~/.kaggle)
# KAGGLE_CONFIG_DIR=~/.kaggle

# BigQuery Configuration
BQ_DATASET=favorita
BQ_RAW_DATASET=raw_favorita
BQ_LOCATION=US

# dbt Configuration
DBT_PROFILES_DIR=./dbt/profiles
DBT_DATASET=favorita
DBT_TARGET=dev

# Vertex AI Configuration
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_REGION=us-central1
VERTEX_AI_STAGING_BUCKET=gs://your-bucket-name/vertex-ai-staging
VERTEX_AI_PIPELINE_ROOT=gs://your-bucket-name/vertex-ai-staging/pipeline-root
VERTEX_AI_MODEL_BUCKET=gs://your-bucket-name/models
# Container image for Vertex Custom Jobs and Pipeline steps (Artifact Registry)
VERTEX_TRAINING_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/your-repo/tds-favorita:latest
# Optional: dedicated SA for Custom Jobs / PipelineJobs (recommended for clients)
VERTEX_PIPELINE_SERVICE_ACCOUNT=sa-vertex-ml@your-gcp-project-id.iam.gserviceaccount.com
# Optional: chargeback labels on Vertex resources
GCP_ENVIRONMENT=dev
GCP_CLIENT_LABEL=client-slug

# MLflow experiment tracking (Vertex jobs via vertex.jobs.run)
# Set EXPERIMENT_TRACKING_ENABLED=false to disable MLflow + Vertex Experiments logging
MLFLOW_TRACKING_URI=file:./mlruns
# Or GCS-backed store: gs://your-bucket/mlflow
MLFLOW_EXPERIMENT_NAME=favorita-vertex
# VERTEX_EXPERIMENT_TRACKING_ENABLED=true

# Model Training Configuration (Optional - can be overridden in config files)
MODEL_TRAIN_DAYS=180
MODEL_TEST_SIZE=0.2
MODEL_FORECAST_HORIZON=7

# Docker Configuration
DOCKER_IMAGE_NAME=tds-favorita
DOCKER_TAG=latest

# Local Development
PYTHONPATH=/app

# Prefect (optional — local OSS server)
# PREFECT_API_URL=http://127.0.0.1:4200/api
# PREFECT_DEFAULT_VERTEX_MODE=docker   # or vertex (no host Python — Docker only)
